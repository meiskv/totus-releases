---
interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Totus — The command center for coding agents",
  description = "Self-hosted command center for coding agents. Triage Slack and Linear, plan the work, and ship it with Claude Code or OpenCode — with you in the loop.",
} = Astro.props;
---

<html lang="en" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Barlow:wght@300;400;500;600;700&family=Instrument+Serif:ital@0;1&display=swap"
      rel="stylesheet"
    />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="icon" href="/favicon.ico" sizes="48x48" />
    <link rel="icon" type="image/png" href="/favicon-32x32.png" sizes="32x32" />
    <link rel="icon" type="image/png" href="/favicon-16x16.png" sizes="16x16" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <title>{title}</title>
  </head>
  <body>
    <div class="page">
      <span id="nav-sentinel" aria-hidden="true"></span>
      <nav class="nav" id="site-nav">
        <a href="/" class="nav-brand">
          <img src="/Totus-Transparent.svg" alt="Totus" class="nav-logo" />
        </a>
        <div class="nav-links">
          <a href="/#orchestration">Workflow</a>
          <a href="/#features">Features</a>
          <a href="/#integrations">Integrations</a>
          <a href="/download">Download</a>
        </div>
        <div class="nav-right">
          <a
            href="https://github.com/totus-dev/totus"
            target="_blank"
            rel="noopener noreferrer"
            class="nav-social"
            title="GitHub"
          >
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 .5C5.37.5 0 5.87 0 12.5c0 5.3 3.44 9.8 8.21 11.39.6.11.82-.26.82-.58v-2.03c-3.34.73-4.04-1.61-4.04-1.61-.55-1.39-1.34-1.76-1.34-1.76-1.09-.75.08-.73.08-.73 1.2.09 1.84 1.24 1.84 1.24 1.07 1.83 2.81 1.3 3.5.99.11-.78.42-1.3.76-1.6-2.67-.3-5.47-1.33-5.47-5.93 0-1.31.47-2.38 1.24-3.22-.13-.3-.54-1.52.11-3.18 0 0 1.01-.32 3.3 1.23a11.5 11.5 0 0 1 6.01 0c2.29-1.55 3.3-1.23 3.3-1.23.65 1.66.24 2.88.12 3.18.77.84 1.23 1.91 1.23 3.22 0 4.61-2.81 5.63-5.49 5.92.43.37.82 1.1.82 2.22v3.29c0 .32.22.7.83.58A12.01 12.01 0 0 0 24 12.5C24 5.87 18.63.5 12 .5z"/></svg>
          </a>
          <a href="/download" class="nav-download">Download</a>
        </div>
      </nav>

      <main class="main">
        <slot />
      </main>

      <footer class="footer">
        <div class="footer-top">
          <div class="footer-brand">
            <span class="footer-copy">&copy; {new Date().getFullYear()} Totus</span>
            <span class="footer-tag">Made with love in Melbourne</span>
            <span class="footer-note">Alpha · open-source soon</span>
          </div>
          <div class="footer-cols">
            <div class="footer-col">
              <span class="footer-col-head">Product</span>
              <a href="/download">Download</a>
              <a href="https://github.com/meiskv/totus-releases/releases" target="_blank" rel="noopener noreferrer">Releases</a>
              <a href="/#features">Features</a>
            </div>
            <div class="footer-col">
              <span class="footer-col-head">Connect</span>
              <a href="https://github.com/totus-dev/totus" target="_blank" rel="noopener noreferrer">GitHub</a>
              <a href="https://www.linkedin.com/in/miksvillamor/" target="_blank" rel="noopener noreferrer">LinkedIn</a>
            </div>
          </div>
        </div>
        <div class="footer-wordmark" aria-hidden="true">totus</div>
      </footer>
    </div>
  </body>
</html>

<script>
  // Toggle the floating-pill nav state once the page scrolls past the top.
  const nav = document.getElementById("site-nav");
  const sentinel = document.getElementById("nav-sentinel");
  if (nav && sentinel && "IntersectionObserver" in window) {
    const io = new IntersectionObserver(
      ([entry]) => nav.classList.toggle("nav--pinned", !entry.isIntersecting),
      { threshold: 0 },
    );
    io.observe(sentinel);
  }
</script>

<style is:global>
  @import "tailwindcss";

  :root {
    --bg: #09090b;
    --fg: #fafafa;
    --fg-muted: #a1a1aa;
    --fg-dim: #71717a;
    --border: rgba(255, 255, 255, 0.08);
    --border-strong: rgba(255, 255, 255, 0.14);
    --accent: #10b981;
    --accent-soft: rgba(16, 185, 129, 0.55);
    --accent-glow: rgba(16, 185, 129, 0.14);
    /* Solid (opaque) card surfaces flattened over --bg, so cards never let the
       background bleed through. Three-step elevation: base → raised → hover. */
    --surface: #0e0e10;
    --surface-raised: #141416;
    --surface-hover: #1b1b1e;
    /* Status accents — mirror the app's thread/plan status colors. */
    --status-working: #7dd3fc;
    --status-done: #5fd6a4;
    --status-merged: #b3a4fb;
    --status-warn: #f4c453;
    --mono: "SF Mono", "SFMono-Regular", Consolas, "Liberation Mono", Menlo, monospace;
    --serif: "Instrument Serif", Georgia, "Times New Roman", serif;
    /* Frosted pill surface for floating nav + CTA (Bond-style). */
    --pill-bg: rgba(14, 14, 16, 0.72);
  }

  * {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  html {
    color-scheme: dark;
    scroll-behavior: smooth;
  }

  /* Fixed pill nav offset so anchored sections never hide under it. */
  :where(section[id], div[id]) {
    scroll-margin-top: 90px;
  }

  body {
    background: var(--bg);
    color: var(--fg);
    font-weight: 500;
    font-family: "Barlow", -apple-system, BlinkMacSystemFont, system-ui, sans-serif;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
    min-height: 100vh;
    overflow-x: hidden;
  }

  body::after {
    content: "";
    position: fixed;
    inset: 0;
    pointer-events: none;
    opacity: 0.035;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
    background-repeat: repeat;
    background-size: 256px 256px;
    z-index: 9999;
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  img {
    display: block;
    max-width: 100%;
  }

  @keyframes fade-in {
    from {
      opacity: 0;
      transform: translateY(8px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* ── Display type (serif) — shared across hero/section headlines ── */

  .display {
    font-family: var(--serif);
    font-weight: 400;
    letter-spacing: -0.02em;
    line-height: 1.02;
    color: var(--fg);
  }

  .display em,
  .display .accent {
    font-style: italic;
    color: var(--accent);
  }

  /* ── Mono eyebrow / micro-label (Warp-style) ── */

  .eyebrow {
    font-family: var(--mono);
    font-size: 0.65rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--accent);
    opacity: 0.9;
  }

  /* ── Frosted pill surface (floating nav + CTA) ── */

  .pill-surface {
    background: var(--pill-bg);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border: 1px solid var(--border-strong);
  }

  /* ── Card surface — dark base with an emerald sheen glowing from the
     top-right corner. Shared by every card/panel wrapper so they read as
     one system instead of flat hollow boxes. ── */

  .card {
    position: relative;
    border: 1px solid var(--border);
    border-radius: 16px;
    background-color: var(--surface);
    background-image:
      radial-gradient(
        90% 85% at 100% 0%,
        rgba(16, 185, 129, 0.15),
        transparent 55%
      ),
      radial-gradient(
        48% 40% at 100% 0%,
        rgba(255, 255, 255, 0.07),
        transparent 52%
      );
    transition:
      border-color 0.3s ease,
      transform 0.3s ease,
      box-shadow 0.3s ease;
  }

  /* Interactive cards lift + brighten their edge and sheen on hover. */
  .card--hover:hover {
    transform: translateY(-2px);
    border-color: var(--border-strong);
    box-shadow: 0 12px 40px -12px rgba(16, 185, 129, 0.18);
  }

  /* ── Emerald horizon — gradient band used at section transitions ── */

  .horizon {
    position: absolute;
    left: 50%;
    transform: translateX(-50%);
    width: 140%;
    height: 480px;
    background: radial-gradient(
      60% 100% at 50% 100%,
      var(--accent-glow),
      transparent 72%
    );
    pointer-events: none;
    z-index: -1;
    filter: blur(8px);
  }

  /* ── Fixed hero backdrop: faint dot-grid fading out below the fold ── */

  .grid-backdrop {
    position: fixed;
    inset: 0;
    z-index: -2;
    pointer-events: none;
    opacity: 0.5;
    background-image: radial-gradient(
      rgba(255, 255, 255, 0.05) 1px,
      transparent 1px
    );
    background-size: 32px 32px;
    -webkit-mask-image: linear-gradient(
      to bottom,
      black 0%,
      transparent 85vh
    );
    mask-image: linear-gradient(to bottom, black 0%, transparent 85vh);
  }

  @media (prefers-reduced-motion: reduce) {
    *,
    *::before,
    *::after {
      animation-duration: 0.001ms !important;
      animation-iteration-count: 1 !important;
      transition-duration: 0.001ms !important;
      scroll-behavior: auto !important;
    }
  }
</style>

<style>
  /* ── Page ── */

  .page {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    overflow-x: hidden;
  }

  /* ── Navbar (transparent → floating pill on scroll) ── */

  .nav {
    position: fixed;
    top: 0;
    left: 50%;
    transform: translateX(-50%);
    z-index: 100;
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
    max-width: 1180px;
    margin: 0 auto;
    padding: 1.4rem 2.5rem;
    border: 1px solid transparent;
    border-radius: 18px;
    background: transparent;
    transition:
      max-width 0.3s ease,
      padding 0.3s ease,
      background 0.3s ease,
      border-color 0.3s ease,
      box-shadow 0.3s ease,
      margin-top 0.3s ease;
  }

  .nav--pinned {
    max-width: 940px;
    margin-top: 0.75rem;
    padding: 0.7rem 1rem 0.7rem 1.4rem;
    background: var(--pill-bg);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border-color: var(--border-strong);
    box-shadow: 0 10px 40px rgba(0, 0, 0, 0.4);
  }

  #nav-sentinel {
    position: absolute;
    top: 0;
    height: 1px;
    width: 1px;
  }

  .nav-brand {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: 1.75rem;
  }

  .nav-links a {
    font-family: var(--mono);
    font-size: 0.7rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--fg-muted);
    transition: color 0.2s ease;
  }

  .nav-links a:hover {
    color: var(--fg);
  }

  .nav-right {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .nav-social {
    display: flex;
    align-items: center;
    color: var(--fg-muted);
    transition: color 0.2s ease;
  }

  .nav-social:hover {
    color: var(--fg);
  }

  .nav-download {
    display: inline-flex;
    align-items: center;
    background: var(--fg);
    color: var(--bg);
    padding: 0.5rem 1.1rem;
    border-radius: 999px;
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: -0.005em;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }

  .nav-download:hover {
    transform: scale(1.03);
    box-shadow: 0 0 24px rgba(255, 255, 255, 0.12);
  }

  .nav-logo {
    height: 34px;
    width: auto;
  }

  /* ── Main content ── */

  .main {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  /* ── Footer ── */

  .footer {
    position: relative;
    width: 100%;
    max-width: 1200px;
    margin: 0 auto;
    padding: 3rem 2.5rem 0;
    border-top: 1px solid var(--border);
    overflow: hidden;
  }

  .footer-top {
    display: flex;
    justify-content: space-between;
    gap: 2rem;
    flex-wrap: wrap;
  }

  .footer-brand {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    font-size: 0.8rem;
  }

  .footer-copy {
    color: var(--fg-muted);
    font-weight: 600;
  }

  .footer-tag {
    color: var(--fg-dim);
  }

  .footer-note {
    font-family: var(--mono);
    font-size: 0.62rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--fg-dim);
  }

  .footer-cols {
    display: flex;
    gap: 3.5rem;
  }

  .footer-col {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .footer-col-head {
    font-family: var(--mono);
    font-size: 0.62rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--fg-dim);
    margin-bottom: 0.15rem;
  }

  .footer-col a {
    font-size: 0.85rem;
    color: var(--fg-muted);
    transition: color 0.3s ease;
  }

  .footer-col a:hover {
    color: var(--fg);
  }

  .footer-wordmark {
    font-family: var(--serif);
    font-size: clamp(6rem, 24vw, 20rem);
    line-height: 0.8;
    letter-spacing: -0.02em;
    text-align: center;
    color: transparent;
    -webkit-text-stroke: 1px var(--border-strong);
    margin: 1.5rem 0 -0.12em;
    user-select: none;
    pointer-events: none;
  }

  /* ── Mobile ── */

  @media (max-width: 860px) {
    .nav-links {
      display: none;
    }
  }

  @media (max-width: 640px) {
    .nav {
      padding: 1rem 1.25rem;
    }

    .nav--pinned {
      padding: 0.6rem 0.75rem 0.6rem 1.1rem;
    }

    .footer {
      padding: 2.5rem 1.25rem 0;
    }

    .footer-cols {
      gap: 2rem;
    }
  }
</style>
