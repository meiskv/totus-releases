---
type Deploy = {
  message: string;
  target: "Production" | "Preview";
  branch: string;
  time: string;
  state: "ready" | "building" | "error";
};

const deployments: Deploy[] = [
  { message: "fix auth token refresh", target: "Production", branch: "main", time: "2m", state: "ready" },
  {
    message: "rate limiting edge case",
    target: "Preview",
    branch: "feat/rate-limit",
    time: "now",
    state: "building",
  },
  {
    message: "dark theme overhaul",
    target: "Preview",
    branch: "refactor/theme",
    time: "1d",
    state: "ready",
  },
];
---

<div class="deploys">
  <div class="deploys-head">
    <span class="deploys-title">
      <svg class="deploys-mark" viewBox="0 0 16 14" aria-hidden="true">
        <path fill="currentColor" d="M8 0 16 14H0z"></path>
      </svg>
      Vercel
    </span>
    <span class="deploys-btn">
      <svg
        viewBox="0 0 16 16"
        fill="none"
        stroke="currentColor"
        stroke-width="1.4"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
      >
        <path d="M8 13V4"></path>
        <path d="m4.5 7.5 3.5-3.5 3.5 3.5"></path>
      </svg>
      Deploy
    </span>
  </div>
  <div class="deploys-list">
    {
      deployments.map((d) => (
        <div class="deploy">
          <span class={`deploy-dot deploy-dot--${d.state}`} />
          <div class="deploy-body">
            <span class="deploy-msg">{d.message}</span>
            <div class="deploy-meta">
              <span
                class={`deploy-env ${d.target === "Production" ? "deploy-env--prod" : "deploy-env--preview"}`}
              >
                {d.target}
              </span>
              <span class="deploy-branch">{d.branch}</span>
              <span class="deploy-time">{d.time}</span>
            </div>
          </div>
        </div>
      ))
    }
  </div>
</div>

<style>
  .deploys {
    width: 100%;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .deploys-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid var(--border);
  }

  .deploys-title {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-family: var(--mono);
    font-size: 0.62rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--fg-dim);
  }

  .deploys-mark {
    width: 11px;
    height: 10px;
    color: var(--fg);
  }

  .deploys-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    font-family: inherit;
    font-size: 0.62rem;
    padding: 0.25rem 0.5rem;
    border-radius: 6px;
    background: var(--surface);
    border: 1px solid var(--border);
    color: var(--fg);
  }

  .deploys-btn svg {
    width: 11px;
    height: 11px;
  }

  .deploys-list {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }

  .deploy {
    display: flex;
    align-items: flex-start;
    gap: 0.55rem;
    padding: 0.45rem 0.45rem;
    border-radius: 8px;
    border: 1px solid transparent;
    transition: background 0.2s ease, border-color 0.2s ease;
  }

  .deploy:hover {
    background: var(--surface-raised);
    border-color: var(--border);
  }

  .deploy-dot {
    width: 7px;
    height: 7px;
    border-radius: 999px;
    margin-top: 0.28rem;
    flex-shrink: 0;
  }

  .deploy-dot--ready {
    background: var(--status-done);
    box-shadow: 0 0 6px rgba(95, 214, 164, 0.5);
  }

  .deploy-dot--building {
    background: #fbbf24;
    box-shadow: 0 0 6px rgba(251, 191, 36, 0.5);
    animation: deploy-pulse 1.4s ease-in-out infinite;
  }

  .deploy-dot--error {
    background: #f87171;
  }

  .deploy-body {
    min-width: 0;
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .deploy-msg {
    font-size: 0.78rem;
    color: var(--fg);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .deploy-meta {
    display: flex;
    align-items: center;
    gap: 0.4rem;
  }

  .deploy-env {
    flex-shrink: 0;
    font-family: var(--mono);
    font-size: 0.54rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    padding: 0.08rem 0.32rem;
    border-radius: 4px;
    border: 1px solid var(--border);
    background: var(--surface);
  }

  .deploy-env--prod {
    color: var(--status-done);
    border-color: rgba(95, 214, 164, 0.3);
  }

  .deploy-env--preview {
    color: var(--fg-muted);
  }

  .deploy-branch {
    font-family: var(--mono);
    font-size: 0.6rem;
    color: var(--fg-dim);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .deploy-time {
    margin-left: auto;
    font-family: var(--mono);
    font-size: 0.58rem;
    color: var(--fg-dim);
    flex-shrink: 0;
  }

  @keyframes deploy-pulse {
    0%,
    100% {
      opacity: 1;
    }
    50% {
      opacity: 0.4;
    }
  }
</style>
