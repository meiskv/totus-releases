---
const CDN = "https://cdn.svglogos.dev/logos";

type Server = {
  name: string;
  src?: string;
  github?: boolean;
  white?: boolean;
  status: "connected" | "needs-auth";
  meta: string;
};

const servers: Server[] = [
  { name: "GitHub", github: true, status: "connected", meta: "21 tools" },
  { name: "Linear", src: "/linear.svg", status: "connected", meta: "12 tools" },
  { name: "Slack", src: "/slack.svg", status: "connected", meta: "9 tools" },
  { name: "Figma", src: `${CDN}/figma.svg`, status: "connected", meta: "8 tools" },
  { name: "Supabase", src: `${CDN}/supabase-icon.svg`, status: "connected", meta: "5 tools" },
  { name: "Sentry", src: `${CDN}/sentry-icon.svg`, white: true, status: "needs-auth", meta: "authenticate" },
];
const connected = servers.filter((s) => s.status === "connected").length;
---

<div class="mcp">
  <div class="mcp-head">
    <span class="mcp-head-icon" aria-hidden="true">
      <svg
        viewBox="0 0 16 16"
        fill="none"
        stroke="currentColor"
        stroke-width="1.2"
        stroke-linecap="round"
        stroke-linejoin="round"
      >
        <rect x="2" y="2.5" width="12" height="4.5" rx="1.2"></rect>
        <rect x="2" y="9" width="12" height="4.5" rx="1.2"></rect>
        <path d="M4 4.75h0.01"></path>
        <path d="M4 11.25h0.01"></path>
      </svg>
    </span>
    <span class="mcp-title">MCP servers</span>
    <span class="mcp-count">{connected}/{servers.length}</span>
    <span class="mcp-add" aria-hidden="true">
      <svg
        viewBox="0 0 16 16"
        fill="none"
        stroke="currentColor"
        stroke-width="1.4"
        stroke-linecap="round"
      >
        <path d="M8 3.5v9M3.5 8h9"></path>
      </svg>
    </span>
  </div>
  <div class="mcp-list">
    {
      servers.map((s) => (
        <div class="mcp-row">
          <span class={`mcp-dot mcp-dot--${s.status}`} />
          <span class="mcp-logo">
            {s.github ? (
              <svg class="mcp-gh" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
                <path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0 0 16 8c0-4.42-3.58-8-8-8z" />
              </svg>
            ) : (
              <img
                src={s.src}
                alt={s.name}
                class={s.white ? "mcp-img-white" : undefined}
                loading="lazy"
              />
            )}
          </span>
          <span class="mcp-name">{s.name}</span>
          <span class={`mcp-meta ${s.status === "needs-auth" ? "mcp-meta--auth" : ""}`}>
            {s.meta}
          </span>
        </div>
      ))
    }
  </div>
</div>

<style>
  .mcp {
    width: 100%;
    display: flex;
    flex-direction: column;
    gap: 0.55rem;
  }

  .mcp-head {
    display: flex;
    align-items: center;
    gap: 0.45rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid var(--border);
  }

  .mcp-head-icon {
    width: 13px;
    height: 13px;
    color: var(--fg-dim);
    display: inline-flex;
  }

  .mcp-head-icon svg {
    width: 100%;
    height: 100%;
  }

  .mcp-title {
    font-family: var(--mono);
    font-size: 0.62rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--fg-dim);
  }

  .mcp-count {
    font-family: var(--mono);
    font-size: 0.6rem;
    color: var(--fg-muted);
  }

  .mcp-add {
    margin-left: auto;
    width: 14px;
    height: 14px;
    color: var(--fg-dim);
    display: inline-flex;
  }

  .mcp-add svg {
    width: 100%;
    height: 100%;
  }

  .mcp-list {
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
  }

  .mcp-row {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.38rem 0.4rem;
    border-radius: 7px;
    border: 1px solid transparent;
    transition: background 0.2s ease, border-color 0.2s ease;
  }

  .mcp-row:hover {
    background: var(--surface-raised);
    border-color: var(--border);
  }

  .mcp-dot {
    width: 6px;
    height: 6px;
    border-radius: 999px;
    flex-shrink: 0;
  }

  .mcp-dot--connected {
    background: var(--status-done);
    box-shadow: 0 0 6px rgba(95, 214, 164, 0.5);
  }

  .mcp-dot--needs-auth {
    background: #fb923c;
    box-shadow: 0 0 6px rgba(251, 146, 60, 0.5);
  }

  .mcp-logo {
    width: 22px;
    height: 22px;
    flex-shrink: 0;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 6px;
    background: var(--surface-raised);
    border: 1px solid var(--border);
    padding: 0.26rem;
  }

  .mcp-logo img,
  .mcp-logo svg {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .mcp-gh {
    color: var(--fg);
  }

  /* Render a dark/colored brand logo as a clean white silhouette. */
  .mcp-img-white {
    filter: brightness(0) invert(1);
  }

  .mcp-name {
    flex: 1;
    min-width: 0;
    font-size: 0.78rem;
    color: var(--fg);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .mcp-meta {
    font-family: var(--mono);
    font-size: 0.58rem;
    color: var(--fg-dim);
    flex-shrink: 0;
  }

  .mcp-meta--auth {
    color: #fb923c;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }
</style>
