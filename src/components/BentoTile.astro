---
interface Props {
  title: string;
  blurb: string;
  span?: "1" | "2";
}
const { title, blurb, span = "1" } = Astro.props;
---

<article class={`tile tile--span-${span} card card--hover`}>
  <div class="tile-visual">
    <slot />
  </div>
  <div class="tile-meta">
    <h3 class="tile-title">{title}</h3>
    <p class="tile-blurb">{blurb}</p>
  </div>
</article>

<style>
  .tile {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    padding: 1.25rem;
    overflow: hidden;
    min-height: 260px;
  }

  .tile--span-2 {
    grid-column: span 2;
  }

  .tile-visual {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 140px;
    position: relative;
    z-index: 1;
  }

  .tile-meta {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }

  .tile-title {
    font-size: 0.95rem;
    font-weight: 600;
    letter-spacing: -0.01em;
    color: var(--fg);
  }

  .tile-blurb {
    font-size: 0.8rem;
    font-weight: 500;
    line-height: 1.5;
    color: var(--fg-muted);
  }

  @media (max-width: 820px) {
    .tile--span-2 {
      grid-column: span 1;
    }
  }
</style>
