---
const rows = [
  { name: "Slack", detail: "acme workspace", icon: "/slack.svg", status: "connected" },
  { name: "Linear", detail: "acme · auto-refreshed", icon: "/linear.svg", status: "connected" },
  { name: "GitHub", detail: "totus-demo/app", icon: "/github.svg", status: "connected" },
];
---

<div class="conns">
  {
    rows.map((r) => (
      <div class="conn">
        <span class="conn-icon" aria-hidden="true">
          <img src={r.icon} alt="" />
        </span>
        <div class="conn-meta">
          <span class="conn-name">{r.name}</span>
          <span class="conn-detail">{r.detail}</span>
        </div>
        <span class="conn-status">
          <span class="conn-dot" />
          {r.status}
        </span>
      </div>
    ))
  }
</div>

<style>
  .conns {
    width: 100%;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .conn {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 0.65rem 0.75rem;
    transition: border-color 0.2s ease, background 0.2s ease;
  }

  .conn:hover {
    border-color: var(--border-strong);
    background: var(--surface-hover);
  }

  .conn-icon {
    width: 16px;
    height: 16px;
    display: inline-flex;
    flex-shrink: 0;
  }

  .conn-icon img {
    width: 100%;
    height: 100%;
  }

  .conn-meta {
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
  }

  .conn-name {
    font-size: 0.78rem;
    font-weight: 600;
    color: var(--fg);
  }

  .conn-detail {
    font-family: var(--mono);
    font-size: 0.55rem;
    color: var(--fg-dim);
  }

  .conn-status {
    margin-left: auto;
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    font-family: var(--mono);
    font-size: 0.55rem;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: #4ec98f;
  }

  .conn-dot {
    width: 5px;
    height: 5px;
    border-radius: 999px;
    background: #4ec98f;
    box-shadow: 0 0 8px rgba(78, 201, 143, 0.5);
  }
</style>
