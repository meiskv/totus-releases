---
const items = [
  { label: "Parse SSE events from OpenCode", state: "done" },
  { label: "Map to orchestration activities", state: "done" },
  { label: "Fix cumulative token accounting", state: "done" },
  { label: "Surface permission requests in UI", state: "active" },
  { label: "Add tests for new mapper", state: "pending" },
  { label: "Update auto-memory entry", state: "pending" },
  { label: "Ship behind CLAUDE_CODE_ENABLED flag", state: "pending" },
];
const done = items.filter((i) => i.state === "done").length;
const shown = items.slice(0, 5);
---

<div class="todo">
  <div class="todo-head">
    <span class="todo-badge">
      <svg class="todo-spark" viewBox="0 0 16 16" aria-hidden="true">
        <path fill="currentColor" d="M8 1.2 9.3 5 13 6.3 9.3 7.6 8 11.4 6.7 7.6 3 6.3 6.7 5z"></path>
      </svg>
      Plan
    </span>
    <span class="todo-count">{done} / {items.length}</span>
  </div>
  <ul class="todo-list">
    {
      shown.map((i) => (
        <li class={`todo-item todo-item--${i.state}`}>
          <span class="todo-mark" aria-hidden="true">
            {i.state === "done" && (
              <svg
                viewBox="0 0 16 16"
                fill="none"
                stroke="currentColor"
                stroke-width="1.4"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <circle cx="8" cy="8" r="5.6" />
                <path d="m5.6 8 1.6 1.7L10.6 6.3" />
              </svg>
            )}
            {i.state === "active" && (
              <svg
                viewBox="0 0 16 16"
                fill="none"
                stroke="currentColor"
                stroke-width="1.4"
                stroke-linecap="round"
              >
                <circle cx="8" cy="8" r="5.6" stroke-dasharray="2.4 2.4" />
              </svg>
            )}
            {i.state === "pending" && (
              <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.4">
                <circle cx="8" cy="8" r="5.6" />
              </svg>
            )}
          </span>
          <span class="todo-label">{i.label}</span>
        </li>
      ))
    }
  </ul>
</div>

<style>
  .todo {
    width: 100%;
    background: var(--surface-raised);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 0.9rem;
    display: flex;
    flex-direction: column;
    gap: 0.65rem;
    font-family: "Barlow", sans-serif;
  }

  .todo-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .todo-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    font-family: var(--mono);
    font-size: 0.62rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--accent);
    background: rgba(16, 185, 129, 0.12);
    border: 1px solid rgba(16, 185, 129, 0.25);
    padding: 0.18rem 0.45rem;
    border-radius: 6px;
  }

  .todo-spark {
    width: 11px;
    height: 11px;
  }

  .todo-count {
    font-family: var(--mono);
    font-size: 0.68rem;
    color: var(--fg-dim);
  }

  .todo-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }

  .todo-item {
    display: flex;
    align-items: flex-start;
    gap: 0.5rem;
    padding: 0.32rem 0.45rem;
    border-radius: 7px;
    font-size: 0.78rem;
    line-height: 1.4;
    color: var(--fg-muted);
  }

  .todo-item--active {
    background: rgba(125, 211, 252, 0.07);
  }

  .todo-mark {
    width: 15px;
    height: 15px;
    flex-shrink: 0;
    margin-top: 0.05rem;
    color: var(--fg-dim);
    display: inline-flex;
  }

  .todo-mark svg {
    width: 100%;
    height: 100%;
  }

  .todo-item--done .todo-mark {
    color: var(--accent);
  }

  .todo-item--done .todo-label {
    color: var(--fg-dim);
    text-decoration: line-through;
    text-decoration-color: rgba(255, 255, 255, 0.18);
  }

  .todo-item--active .todo-mark {
    color: var(--status-working);
    animation: todo-pulse 1.5s ease-in-out infinite;
  }

  .todo-item--active .todo-label {
    color: var(--fg);
  }

  @keyframes todo-pulse {
    0%,
    100% {
      opacity: 1;
    }
    50% {
      opacity: 0.45;
    }
  }
</style>
