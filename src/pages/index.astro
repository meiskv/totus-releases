---
import Layout from "../layouts/Layout.astro";
import ValueTicker from "../components/ValueTicker.astro";
import BentoTile from "../components/BentoTile.astro";
import MockMcpRow from "../components/MockMcpRow.astro";
import MockTokenMeter from "../components/MockTokenMeter.astro";
import MockApproval from "../components/MockApproval.astro";
import MockDeploys from "../components/MockDeploys.astro";
import MockTodoList from "../components/MockTodoList.astro";
import MockThreadList from "../components/MockThreadList.astro";
import MockAgentStatus from "../components/MockAgentStatus.astro";
import MockTriageBoard from "../components/MockTriageBoard.astro";
import MockPlanCard from "../components/MockPlanCard.astro";
import MockConnections from "../components/MockConnections.astro";
import MockMemory from "../components/MockMemory.astro";
import EyebrowBoard from "../components/EyebrowBoard.tsx";
---

<Layout>
  <div class="grid-backdrop" aria-hidden="true"></div>

  <!-- ───────────────── Hero ───────────────── -->
  <section class="hero">
    <div class="hero-badges">
      <span class="badge"><span class="badge-dot" aria-hidden="true"></span>Alpha</span>
      <span class="badge badge--board"><EyebrowBoard client:load /></span>
      <span class="badge">Open-source soon</span>
    </div>

    <div class="hero-grid">
      <h1 class="hero-title display">Your week is triaged.</h1>
      <p class="hero-sub">
        Totus is a self-hosted command center for coding agents. It catches
        <span class="brand"><img class="brand-ico" src="/slack.svg" alt="" width="16" height="16" loading="lazy" />Slack</span> pings and <span class="brand"><img class="brand-ico" src="/linear.svg" alt="" width="16" height="16" loading="lazy" />Linear</span> tickets,
        plans the work, and ships it with <span class="brand"><img class="brand-ico" src="/claude.svg" alt="" width="16" height="16" loading="lazy" />Claude&nbsp;Code</span>,
        <span class="brand"><img class="brand-ico" src="/opencode-logo-dark.svg" alt="" width="16" height="16" loading="lazy" />OpenCode</span>, or <span class="brand"><img class="brand-ico" src="/codex.svg" alt="" width="16" height="16" loading="lazy" />Codex<span class="brand-wip">WIP</span></span>
        — with you in the loop.
      </p>
    </div>

    <div class="cta-row">
      <a
        href="/download"
        class="hero-button"
      >
        <svg class="hero-button-icon hero-button-icon--apple" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 814 1000" aria-hidden="true"><path fill="currentColor" d="M788.1 340.9c-5.8 4.5-108.2 62.2-108.2 190.5 0 148.4 130.3 200.9 134.2 202.2-.6 3.2-20.7 71.9-68.7 141.9-42.8 61.6-87.5 123.1-155.5 123.1s-85.5-39.5-164-39.5c-76.5 0-103.7 40.8-165.9 40.8s-105.6-57-155.5-127C46.7 790.7 0 663 0 541.8c0-194.4 126.4-297.5 250.8-297.5 66.1 0 121.2 43.4 162.7 43.4 39.5 0 101.1-46 176.3-46 28.5 0 130.9 2.6 198.3 99.2zm-234-181.5c31.1-36.9 53.1-88.1 53.1-139.3 0-7.1-.6-14.3-1.9-20.1-50.6 1.9-110.8 33.7-147.1 75.8-28.5 32.4-55.1 83.6-55.1 135.5 0 7.8 1.3 15.6 1.9 18.1 3.2.6 8.4 1.3 13.6 1.3 45.4 0 102.5-30.4 135.5-71.3z"></path></svg>
        <svg class="hero-button-icon hero-button-icon--windows" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 88 88" aria-hidden="true"><path fill="currentColor" d="m0 12.402 35.687-4.86.016 34.423-35.67.203zm35.67 33.529.028 34.453L.028 75.48.026 45.7zm4.326-39.025L87.314 0v41.527l-47.318.376zm47.329 39.349-.011 41.34-47.318-6.678-.066-34.739z"></path></svg>
        <svg class="hero-button-icon hero-button-icon--linux" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" aria-hidden="true"><path fill="currentColor" d="M12.504 0c-.155 0-.315.008-.48.021-4.226.333-3.105 4.807-3.17 6.298-.076 1.092-.3 1.953-1.05 3.02-.885 1.051-2.127 2.75-2.716 4.521-.278.832-.41 1.684-.287 2.489a.424.424 0 0 0-.11.135c-.26.268-.45.6-.663.839-.199.199-.485.267-.797.4-.313.136-.658.269-.864.68-.09.189-.136.394-.132.602 0 .199.027.4.055.6.058.399.116.755.042.988-.236.629-.265 1.06-.102 1.365.164.304.475.448.806.547.66.196 1.58.125 2.334.543.806.446 1.64.718 2.31.679.49-.029.919-.212 1.229-.619.154-.2.315-.5.499-.571.186-.071.52-.052.853-.03.494.02 1.032.015 1.522-.006.486-.02 1.015-.03 1.547-.006.525.022.91.02 1.395.014.498-.005 1.044.004 1.583.006.33.002.688-.018.89.051.201.07.387.248.495.454.143.273.275.471.435.568.353.219 1.172.3 1.875.053.712-.249 1.57-.596 2.296-.878.706-.274 1.524-.245 2.195-.459.337-.105.622-.28.798-.522.176-.239.249-.556.233-.876-.024-.52-.257-.974-.516-1.334-.258-.36-.54-.603-.693-.832-.151-.228-.213-.451-.3-.703-.09-.253-.176-.473-.335-.672-.158-.201-.393-.305-.632-.393-.239-.088-.48-.16-.625-.276-.147-.118-.236-.247-.323-.473-.09-.226-.16-.574-.299-.82-.138-.244-.362-.416-.605-.583-.243-.167-.52-.372-.605-.6-.086-.228-.076-.466.024-.733.098-.27.268-.546.358-.838.094-.292.152-.583.166-.872.012-.29-.014-.575-.097-.853-.154-.513-.377-.983-.587-1.455-.199-.47-.384-.965-.414-1.422-.031-.46.064-.884.26-1.296.193-.412.44-.787.72-1.12.143-.166.29-.33.442-.489.152-.158.31-.316.45-.473.146-.157.271-.311.373-.46.209-.291.343-.563.373-.839.03-.275-.03-.545-.169-.8-.14-.253-.354-.485-.63-.692-.276-.206-.615-.386-1.017-.53-.401-.144-.867-.252-1.396-.306-.528-.054-1.12-.054-1.773-.054-1.307 0-2.914.05-4.45.099-1.535.05-2.966.099-4.14.099z"></path></svg>
        <span class="js-download-label">Download</span>
      </a>
      <a
        href="https://github.com/totus-dev/totus"
        target="_blank"
        rel="noopener noreferrer"
        class="hero-secondary"
      >
        View on GitHub
      </a>
      <span class="cta-note">Free while in alpha</span>
    </div>

    <div class="horizon hero-horizon" aria-hidden="true"></div>
  </section>

  <!-- ───────────────── Value ticker ───────────────── -->
  <ValueTicker />

  <!-- ───────────────── Interactive demo (desktop) / screenshot (mobile) ───────────────── -->
  <div class="screenshot-wrap reveal">
    <div class="demo-glow" aria-hidden="true"></div>
    <div class="demo-desktop" id="demo-wrap">
      <div class="chrome-bar" aria-hidden="true">
        <span class="chrome-dots">
          <span class="chrome-dot" style="background:#ff5f57"></span>
          <span class="chrome-dot" style="background:#febc2e"></span>
          <span class="chrome-dot" style="background:#28c840"></span>
        </span>
        <span class="chrome-label">totus — local workspace</span>
      </div>
      <div class="demo-overlay" id="demo-overlay">
        <span class="demo-overlay-hint">Click to interact</span>
      </div>
      <iframe
        class="app-demo-frame"
        src="/app-demo/demo.html"
        title="Totus — interactive demo"
        loading="lazy"
      ></iframe>
    </div>
    <div class="screenshot-mobile">
      <div class="chrome-bar" aria-hidden="true">
        <span class="chrome-dots">
          <span class="chrome-dot" style="background:#ff5f57"></span>
          <span class="chrome-dot" style="background:#febc2e"></span>
          <span class="chrome-dot" style="background:#28c840"></span>
        </span>
        <span class="chrome-label">totus — local workspace</span>
      </div>
      <img src="/hero.svg" alt="Totus interface" class="screenshot" />
    </div>
  </div>

  <span id="pill-sentinel" aria-hidden="true"></span>

  <div class="below-fold">
    <!-- ───────────────── Orchestration ───────────────── -->
    <section class="section" id="orchestration">
      <header class="section-header">
        <span class="eyebrow">orchestration</span>
        <h2 class="section-title display">From signal to shipped.</h2>
        <p class="section-sub">Every signal flows through one workspace.</p>
      </header>

      <div class="orch">
        <div class="orch-row reveal">
          <div class="orch-copy">
            <span class="orch-step">01 · Triage</span>
            <h3 class="orch-title display">Nothing slips.</h3>
            <p class="orch-body">
              Slack mentions, Linear tickets, review requests — pulled into one
              board and ranked, so the most important thing is always on top.
            </p>
          </div>
          <div class="orch-divider" aria-hidden="true"></div>
          <div class="orch-visual card"><MockTriageBoard /></div>
        </div>

        <div class="orch-row orch-row--flip reveal">
          <div class="orch-copy">
            <span class="orch-step">02 · Plan</span>
            <h3 class="orch-title display">Plan without touching the repo.</h3>
            <p class="orch-body">
              The Knowledge orchestrator reads code, Slack, and Linear, drafts
              plans in generative cards, and writes them back where your team
              lives. Repo edits stay in Code threads.
            </p>
          </div>
          <div class="orch-divider" aria-hidden="true"></div>
          <div class="orch-visual card"><MockPlanCard /></div>
        </div>

        <div class="orch-row reveal">
          <div class="orch-copy">
            <span class="orch-step">03 · Ship</span>
            <h3 class="orch-title display">Hand off. Watch it ship.</h3>
            <p class="orch-body">
              Approved plans become Code threads — agents build, you review diffs
              and approve, and sessions persist with checkpoints and PR status.
            </p>
          </div>
          <div class="orch-divider" aria-hidden="true"></div>
          <div class="orch-visual card"><MockThreadList /></div>
        </div>
      </div>

      <div class="domains reveal">
        <span class="eyebrow domains-eyebrow">Three domains · one workspace</span>
        <div class="domains-grid card">
          <div class="domain">
            <span class="domain-name">Code</span>
            <span class="domain-line">Full agent orchestration — diffs, approvals, git.</span>
          </div>
          <div class="domain">
            <span class="domain-name">Knowledge</span>
            <span class="domain-line">Read-only triage and planning across Slack and Linear.</span>
          </div>
          <div class="domain">
            <span class="domain-name">Marketing</span>
            <span class="domain-line">Copy and campaigns with the same approval flow.</span>
          </div>
        </div>
      </div>
    </section>

    <!-- ───────────────── Bento ───────────────── -->
    <section class="section" id="features">
      <header class="section-header">
        <span class="eyebrow">why a GUI</span>
        <h2 class="section-title display">What the terminal can't show you.</h2>
      </header>

      <div class="bento reveal">
        <BentoTile title="MCP servers" blurb="Toggle, reconnect, authenticate — one panel.">
          <MockMcpRow />
        </BentoTile>
        <BentoTile title="Token tracking" blurb="Context window, in/out tokens, cost — live.">
          <MockTokenMeter />
        </BentoTile>
        <BentoTile title="Approvals" blurb="Approve, deny, move on. Permissions and questions get their own panel.">
          <MockApproval />
        </BentoTile>
        <BentoTile title="Plan view" blurb="The agent's todo list, inline. Progress in real time.">
          <MockTodoList />
        </BentoTile>
        <BentoTile title="Deploys" blurb="Trigger Vercel deploys, watch Production and Preview — live.">
          <MockDeploys />
        </BentoTile>
        <BentoTile title="Sub-agents" blurb="Every child agent gets a live status row.">
          <MockAgentStatus />
        </BentoTile>
      </div>

      <div class="memory-strip card reveal">
        <div class="memory-copy">
          <span class="eyebrow">shared memory</span>
          <p class="memory-line">
            Preferences and patterns carry across every project. No manual config.
          </p>
        </div>
        <div class="memory-visual"><MockMemory /></div>
      </div>
    </section>

    <!-- ───────────────── Integrations ───────────────── -->
    <section class="section section--split" id="integrations">
      <div class="split-copy">
        <span class="eyebrow">integrations</span>
        <h2 class="section-title section-title--small display">Wired into where work lives.</h2>
        <p class="section-sub section-sub--left">
          Per-workspace OAuth that renews itself — expired tokens refresh
          automatically and credentials never leave your machine.
        </p>
        <div class="int-list">
          <div class="int-row">
            <span class="int-icon"><img src="/slack.svg" alt="Slack" /></span>
            <span class="int-name">Slack</span>
            <span class="int-detail">DMs, mentions, channels, threads</span>
          </div>
          <div class="int-row">
            <span class="int-icon"><img src="/linear.svg" alt="Linear" /></span>
            <span class="int-name">Linear</span>
            <span class="int-detail">Tickets, assignments, status</span>
          </div>
          <div class="int-row int-row--coming">
            <span class="int-icon int-icon--dim">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 .5C5.37.5 0 5.87 0 12.5c0 5.3 3.44 9.8 8.21 11.39.6.11.82-.26.82-.58v-2.03c-3.34.73-4.04-1.61-4.04-1.61-.55-1.39-1.34-1.76-1.34-1.76-1.09-.75.08-.73.08-.73 1.2.09 1.84 1.24 1.84 1.24 1.07 1.83 2.81 1.3 3.5.99.11-.78.42-1.3.76-1.6-2.67-.3-5.47-1.33-5.47-5.93 0-1.31.47-2.38 1.24-3.22-.13-.3-.54-1.52.11-3.18 0 0 1.01-.32 3.3 1.23a11.5 11.5 0 0 1 6.01 0c2.29-1.55 3.3-1.23 3.3-1.23.65 1.66.24 2.88.12 3.18.77.84 1.23 1.91 1.23 3.22 0 4.61-2.81 5.63-5.49 5.92.43.37.82 1.1.82 2.22v3.29c0 .32.22.7.83.58A12.01 12.01 0 0 0 24 12.5C24 5.87 18.63.5 12 .5z"/></svg>
            </span>
            <span class="int-name">GitHub</span>
            <span class="int-detail">PRs, reviews, CI checks</span>
            <span class="int-badge">Coming</span>
          </div>
          <div class="int-row int-row--coming">
            <span class="int-icon int-icon--dim">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="10"/><path d="M12 8v4l3 3"/></svg>
            </span>
            <span class="int-name">Notion</span>
            <span class="int-detail">Docs, wikis, databases</span>
            <span class="int-badge">Coming</span>
          </div>
        </div>
      </div>
      <div class="split-visual">
        <div class="mock-panel card"><MockConnections /></div>
      </div>
    </section>

    <!-- ───────────────── Manifesto ───────────────── -->
    <section class="manifesto reveal">
      <div class="horizon manifesto-horizon" aria-hidden="true"></div>
      <p class="manifesto-text display">
        The terminal is a great engine.<br />
        <em>It's a terrible cockpit.</em>
      </p>
      <span class="eyebrow manifesto-eyebrow">why Totus exists</span>
    </section>

    <!-- ───────────────── Bottom CTA ───────────────── -->
    <section class="section section--cta" id="cta">
      <div class="horizon cta-horizon" aria-hidden="true"></div>
      <h2 class="cta-title display">Start triaging.</h2>
      <p class="cta-sub">Self-hosted. Open-source soon. Alpha — expect rough edges.</p>
      <div class="cta-row cta-row--center">
        <a
          href="https://github.com/meiskv/totus-releases/releases"
          class="hero-button js-download"
        >
          <span class="js-download-label">Download</span>
        </a>
        <a
          href="https://github.com/totus-dev/totus"
          target="_blank"
          rel="noopener noreferrer"
          class="hero-secondary"
        >
          View on GitHub
        </a>
        <a href="/download" class="cta-all">All platforms →</a>
      </div>
    </section>
  </div><!-- .below-fold -->

  <!-- ───────────────── Floating download pill ───────────────── -->
  <a
    href="https://github.com/meiskv/totus-releases/releases"
    class="float-pill js-download"
    id="float-pill"
  >
    Download Totus →
  </a>
</Layout>

<script>
  import { initHome } from "../lib/home";

  initHome();
</script>

<style>
  /* ──────────────── Reveal ──────────────── */

  :global(.reveal) {
    opacity: 0;
    transform: translateY(18px);
    transition:
      opacity 0.9s ease-out,
      transform 0.9s ease-out;
  }

  :global(.reveal--in) {
    opacity: 1;
    transform: translateY(0);
  }

  /* ──────────────── Hero ──────────────── */

  .hero {
    position: relative;
    padding: 10rem 1.5rem 4rem;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    text-align: left;
    max-width: 1180px;
    width: 100%;
    margin: 0 auto;
  }

  .hero-badges {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
    margin-bottom: 2rem;
    opacity: 0;
    animation: fade-in 1s ease-out forwards;
  }

  .badge {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-family: var(--mono);
    font-size: 0.62rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--fg-muted);
    padding: 0.35rem 0.7rem;
    border: 1px solid var(--border);
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.02);
  }

  .badge--board {
    padding-block: 0.3rem;
  }

  .badge-dot {
    width: 5px;
    height: 5px;
    border-radius: 999px;
    background: var(--accent);
    box-shadow: 0 0 8px var(--accent-soft);
  }

  .hero-grid {
    display: grid;
    grid-template-columns: 1.3fr 1fr;
    gap: 2.5rem 3.5rem;
    align-items: start;
    width: 100%;
  }

  .hero-title {
    font-size: clamp(2.8rem, 7vw, 5rem);
    margin: 0;
    opacity: 0;
    animation: fade-in 1s ease-out 0.1s forwards;
  }

  .hero-sub {
    font-size: clamp(0.95rem, 1.2vw, 1.05rem);
    font-weight: 500;
    line-height: 1.6;
    color: var(--fg-muted);
    max-width: 36ch;
    margin: 0 0 0.4rem;
    opacity: 0;
    animation: fade-in 1s ease-out 0.2s forwards;
  }

  .brand {
    display: inline-flex;
    align-items: center;
    gap: 0.3em;
    white-space: nowrap;
    font-weight: 600;
    color: var(--fg);
  }

  .brand-ico {
    width: 1em;
    height: 1em;
    border-radius: 3px;
    vertical-align: -0.15em;
    flex-shrink: 0;
  }

  .brand-wip {
    margin-left: 0.35em;
    font-size: 0.62em;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--fg-dim);
    border: 1px solid var(--border);
    border-radius: 4px;
    padding: 0.05em 0.32em;
  }

  .cta-row {
    display: flex;
    gap: 0.65rem;
    align-items: center;
    flex-wrap: wrap;
    margin-top: 2.5rem;
    opacity: 0;
    animation: fade-in 1s ease-out 0.3s forwards;
  }

  .cta-note {
    font-family: var(--mono);
    font-size: 0.62rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--fg-dim);
  }

  .hero-horizon {
    top: auto;
    bottom: -260px;
  }

  .hero-button {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    background: var(--fg);
    color: var(--bg);
    padding: 0.7rem 1.5rem;
    border-radius: 999px;
    font-weight: 600;
    font-size: 0.88rem;
    letter-spacing: -0.005em;
    transition: transform 0.25s ease, box-shadow 0.25s ease;
  }

  .hero-button:hover {
    transform: scale(1.02);
    box-shadow: 0 0 30px rgba(255, 255, 255, 0.1);
  }

  .hero-button:active {
    transform: scale(0.98);
  }

  .hero-button-icon {
    display: none;
    width: 1em;
    height: 1em;
    flex-shrink: 0;
  }

  :global([data-platform="mac"]) .hero-button-icon--apple {
    display: block;
  }

  :global([data-platform="win"]) .hero-button-icon--windows {
    display: block;
  }

  :global([data-platform="linux"]) .hero-button-icon--linux {
    display: block;
  }

  .hero-secondary {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    color: var(--fg-muted);
    padding: 0.7rem 1.2rem;
    border-radius: 999px;
    font-size: 0.88rem;
    border: 1px solid var(--border);
    transition: color 0.25s ease, border-color 0.25s ease, background 0.25s ease;
  }

  .hero-secondary:hover {
    color: var(--fg);
    border-color: var(--border-strong);
    background: var(--surface);
  }

  /* ──────────────── Demo screenshot ──────────────── */

  .screenshot-wrap {
    margin: 5vh auto 8vh;
    width: min(95vw, 1280px);
    position: relative;
  }

  .demo-glow {
    position: absolute;
    inset: -10% 0 0;
    background: radial-gradient(
      50% 60% at 50% 30%,
      var(--accent-glow),
      transparent 70%
    );
    filter: blur(40px);
    pointer-events: none;
    z-index: -1;
  }

  .chrome-bar {
    height: 34px;
    display: flex;
    align-items: center;
    gap: 0.6rem;
    padding: 0 0.85rem;
    background: var(--surface-raised);
    border-bottom: 1px solid var(--border);
    position: relative;
    z-index: 3;
  }

  .chrome-dots {
    display: inline-flex;
    gap: 6px;
  }

  .chrome-dot {
    width: 10px;
    height: 10px;
    border-radius: 999px;
    opacity: 0.55;
  }

  .chrome-label {
    position: absolute;
    left: 50%;
    transform: translateX(-50%);
    font-family: var(--mono);
    font-size: 0.7rem;
    color: var(--fg-dim);
  }

  .demo-desktop {
    display: block;
    width: 100%;
    overflow: hidden;
    border: 1px solid var(--border-strong);
    border-radius: 18px;
    background: #0a0a0a;
    aspect-ratio: 1280 / 794;
    position: relative;
    box-shadow: 0 30px 80px rgba(0, 0, 0, 0.45);
  }

  .app-demo-frame {
    width: 1280px;
    height: 760px;
    border: 0;
    display: block;
